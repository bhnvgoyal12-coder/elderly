<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Notification Indicator -->
        <LinearLayout
            android:id="@+id/notificationIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_notification_indicator"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/bg_red_dot" />

            <TextView
                android:id="@+id/notificationText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="@string/new_notifications"
                android:textSize="16sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tap_to_view"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

        <!-- Quick Call Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/quick_call"
                    style="@style/SectionHeader" />

                <ImageView
                    android:id="@+id/btnQuickCallInfo"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_info"
                    android:padding="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/quick_call_help"
                    app:tint="@color/text_secondary" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/favoriteContactsRecycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:orientation="horizontal"
                tools:listitem="@layout/item_favorite_contact" />

        </LinearLayout>

        <!-- Main Actions Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="12dp"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="3"
                android:alignmentMode="alignMargins"
                android:useDefaultMargins="false">

                <!-- Phone Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPhone"
                    style="@style/LauncherButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="@string/phone"
                    android:backgroundTint="@color/button_phone"
                    app:icon="@drawable/ic_phone"
                    app:iconSize="44dp"
                    app:iconTint="@color/button_text" />

                <!-- SMS Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMessages"
                    style="@style/LauncherButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="@string/messages"
                    android:backgroundTint="@color/button_messages"
                    app:icon="@drawable/ic_message"
                    app:iconSize="44dp"
                    app:iconTint="@color/button_text" />

                <!-- WhatsApp Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWhatsApp"
                    style="@style/LauncherButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="@string/whatsapp"
                    android:backgroundTint="@color/button_whatsapp"
                    app:icon="@drawable/ic_whatsapp"
                    app:iconSize="44dp"
                    app:iconTint="@color/button_text" />

                <!-- Camera Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCamera"
                    style="@style/LauncherButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="@string/camera"
                    android:backgroundTint="@color/button_camera"
                    app:icon="@drawable/ic_camera"
                    app:iconSize="44dp"
                    app:iconTint="@color/button_text" />

                <!-- Photos Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPhotos"
                    style="@style/LauncherButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="@string/photos"
                    android:backgroundTint="@color/button_photos"
                    app:icon="@drawable/ic_photos"
                    app:iconSize="44dp"
                    app:iconTint="@color/button_text" />

                <!-- All Apps Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAllApps"
                    style="@style/LauncherButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="@string/all_apps"
                    android:backgroundTint="@color/button_all_apps"
                    app:icon="@drawable/ic_apps"
                    app:iconSize="44dp"
                    app:iconTint="@color/button_text" />

            </GridLayout>

        </LinearLayout>

        <!-- My Apps Section (Favorites) -->
        <LinearLayout
            android:id="@+id/myAppsSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:elevation="2dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/myAppsHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/my_apps"
                style="@style/SectionHeader"
                android:layout_marginBottom="12dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/favoriteAppsRecycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                tools:listitem="@layout/item_favorite_app" />

        </LinearLayout>

        <!-- Empty state hint -->
        <LinearLayout
            android:id="@+id/emptyAppsHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="24dp"
            android:elevation="2dp"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_add"
                android:alpha="0.5"
                app:tint="@color/text_secondary"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/add_apps_hint"
                android:textSize="16sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <!-- Swipe hints -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/swipe_hint_left"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:shadowColor="#80000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:drawableStart="@drawable/ic_arrow_left"
                android:drawablePadding="4dp"
                android:gravity="center_vertical" />

            <View
                android:layout_width="48dp"
                android:layout_height="1dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/swipe_hint_right"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:shadowColor="#80000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:drawableEnd="@drawable/ic_arrow_right"
                android:drawablePadding="4dp"
                android:gravity="center_vertical" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
